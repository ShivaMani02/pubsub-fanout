{
  "name": "pubsub-fanout",
  "version": "1.0.0",
  "description": "Real-time Pub/Sub message system with fanout distribution and performance monitoring",
  "main": "server/src/index.js",
  "scripts": {
    "dev": "concurrently \"cd server && npm run dev\" \"cd client && npm start\"",
    "start": "cd server && npm start",
    "server": "cd server && npm start",
    "client": "cd client && npm start",
    "build": "cd client && npm run build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:rebuild": "docker-compose up -d --build",
    "install:all": "npm install && cd server && npm install && cd ../client && npm install"
  },
  "keywords": [
    "pubsub",
    "messaging",
    "real-time",
    "fanout",
    "redis",
    "mongodb",
    "websocket"
  ],
  "author": "Your Team",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.0"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/pubsub-fanout.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/pubsub-fanout/issues"
  },
  "homepage": "https://github.com/yourusername/pubsub-fanout#readme"
}
