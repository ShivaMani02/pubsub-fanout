# ============================================
# PubSub Fanout - Environment Configuration
# ============================================
# Copy this file to server/.env and update values as needed

# ============================================
# Database Configuration
# ============================================
# For Docker Compose: use service names (mongodb, redis)
# For Local Development: use localhost
MONGO_URI=mongodb://root:mongo_password@mongodb:27017/pubsub_db?authSource=admin
MONGO_USER=root
MONGO_PASSWORD=mongo_password

# Redis Pub/Sub Broker
REDIS_URL=redis://:redis_password@redis:6379

# ============================================
# Server Configuration
# ============================================
NODE_ENV=development
PORT=5000
HOST=0.0.0.0

# CORS Configuration (for frontend)
CORS_ORIGIN=http://localhost:3000

# Logging Level: debug, info, warn, error
LOG_LEVEL=debug

# ============================================
# Frontend Configuration
# ============================================
# Copy these to client/.env
REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_SOCKET_URL=http://localhost:5000

# ============================================
# Simulation Default Parameters
# ============================================
# Default values for test simulations
SIM_PUBLISHERS=3
SIM_SUBSCRIBERS=10
SIM_DURATION=60000
SIM_MESSAGE_RATE=5
SIM_PARTITIONS=4
MESSAGE_BATCH_SIZE=10
MESSAGE_INTERVAL_MS=1000

# ============================================
# Optional: Advanced Configuration
# ============================================
# Database timeouts and retries
MONGO_MAX_RETRIES=5
MONGO_RETRY_DELAY=5000
MONGO_TIMEOUT=5000

# Redis settings
REDIS_RECONNECT_STRATEGY=exponential
REDIS_MAX_RETRIES=10
