  "item": [
    {
      "name": "Messages",
      "item": [
        {
          "name": "Publish Message",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Session-ID",
                "value": "session_xyz",
                "disabled": true
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"topic\": \"orders\",\n  \"message\": {\n    \"orderId\": \"order_123\",\n    \"amount\": 99.99,\n    \"status\": \"pending\"\n  },\n  \"partitionKey\": \"user_456\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/messages/publish",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "messages", "publish"]
            },
            "description": "Publish a new message to a topic. The message is distributed to all subscribers of that topic."
          },
          "response": [
            {
              "name": "Success Response",
              "originalRequest": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"topic\": \"orders\",\n  \"message\": {\n    \"orderId\": \"order_123\",\n    \"amount\": 99.99\n  }\n}"
                },
                "url": {
                  "raw": "http://localhost:5000/api/messages/publish",
                  "protocol": "http",
                  "host": ["localhost"],
                  "port": "5000",
                  "path": ["api", "messages", "publish"]
                }
              },
              "status": "OK",
              "code": 200,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"success\": true,\n  \"messageId\": \"msg_1234567890\",\n  \"topic\": \"orders\",\n  \"fanoutCount\": 5,\n  \"latency\": 23,\n  \"publishedAt\": \"2024-03-05T10:30:45.123Z\"\n}"
            }
          ]
        },
